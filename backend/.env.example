# Servidor
NODE_ENV=development
PORT=3000

# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mensajeria?schema=public"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Firebase Admin SDK
# Ruta al service-account.json descargado de Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# Uploads
UPLOAD_DIR="./uploads"
PUBLIC_URL="http://localhost:3000"